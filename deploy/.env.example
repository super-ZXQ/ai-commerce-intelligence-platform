# 电商数据分析系统 - Docker Compose 环境变量
# 复制此文件为 .env 并修改配置

# MySQL
DB_PASSWORD=123456
DB_NAME=ecommerce_analysis
DB_PORT=3306

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=

# FastAPI 后端
BACKEND_PORT=8000
JWT_SECRET=change-this-secret-in-production
DEBUG=false

# Streamlit BI 看板
STREAMLIT_PORT=8501

# AI 分析助手
AI_PORT=8502
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
